# ── Never send these to the Docker build context ──────────────────────────────

# Dependencies — reinstalled fresh inside the container
node_modules

# Previous build output — builder stage creates a clean one
.next
out

# Environment files — secrets must come from Railway env vars, never from files
.env
.env.*

# Dev tooling
coverage
*.log
npm-debug.log*

# OS / Editor
.DS_Store
Thumbs.db
.vscode
.idea

# Git
.git
.gitignore

# Docker itself
Dockerfile
.dockerignore

# Local dev
docker-compose.yml
docker-compose.override.yml

# TypeScript incremental cache
*.tsbuildinfo
