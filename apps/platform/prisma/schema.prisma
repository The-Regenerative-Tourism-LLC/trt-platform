generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum AppRole {
  operator
  traveler
  admin
  institution_partner

  @@map("app_role")
}

enum OperatorType {
  A
  B
  C
}

enum P3Status {
  A
  B
  C
  D
  E
}

enum PressureLevel {
  low
  moderate
  high
}

enum GPSBand {
  regenerative_leader
  regenerative_practice
  advancing
  developing
  not_yet_published
}

enum DPSBand {
  accelerating
  progressing
  stable
  regressing
  critical
}

enum EvidenceTier {
  T1
  T2
  T3
  Proxy
}

enum VerificationState {
  pending
  verified
  rejected
  lapsed
}

enum ForwardCommitmentStatus {
  pending
  matched
  activated
  lapsed
}

enum BookingStatus {
  booked
  completed
  cancelled
}

enum ActivityDifficulty {
  easy
  moderate
  challenging
}

enum BadgeType {
  first_checkin
  first_encounter
  levada_explorer
  eel_guardian
  marine_guardian
  forest_guardian
  soil_guardian
  culture_keeper
  community_builder
  regenerator
}

enum SightingStatus {
  pending
  confirmed
  rejected
}

enum NotificationType {
  score_published
  evidence_verified
  evidence_rejected
  booking_confirmed
  trip_completed
  badge_earned
  mission_update
  system
}

// ── Identity & Auth ────────────────────────────────────────────────────────

// Auth.js v5 / NextAuth User model
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  roles    UserRole[]
  operator Operator?
  traveler Traveler?

  @@map("users")
}

// Auth.js v5 standard — OAuth account linking
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Auth.js v5 standard — kept for adapter compatibility even with JWT strategy
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Auth.js v5 standard — email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model UserRole {
  id     String  @id @default(cuid())
  userId String
  role   AppRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

// ── Territory ──────────────────────────────────────────────────────────────

model Territory {
  id                   String         @id @default(cuid())
  name                 String
  country              String?
  touristIntensity     Decimal?       @db.Decimal(6, 2)
  ecologicalSensitivity Decimal?      @db.Decimal(6, 2)
  economicLeakageRate  Decimal?       @db.Decimal(6, 2)
  regenerativePerformance Decimal?    @db.Decimal(6, 2)
  compositeDpi         Decimal?       @db.Decimal(6, 2)
  pressureLevel        PressureLevel?
  operatorCohortSize   Int            @default(0)
  dpiComputedAt        DateTime?
  createdAt            DateTime       @default(now())

  operators            Operator[]
  assessmentSnapshots  AssessmentSnapshot[]
  dpiSnapshots         DpiSnapshot[]

  @@map("territories")
}

// ── Operator ───────────────────────────────────────────────────────────────

model Operator {
  id                    String        @id @default(cuid())
  userId                String?       @unique
  legalName             String
  tradingName           String?
  country               String?
  destinationRegion     String?
  territoryId           String?
  operatorType          OperatorType?
  operatorCode          String?       @unique
  yearOperationStart    Int?
  website               String?
  primaryContactName    String?
  primaryContactEmail   String?
  accommodationCategory String?
  rooms                 Int?
  bedCapacity           Int?
  experienceTypes       String[]
  ownershipType         String?
  localEquityPct        Decimal?      @db.Decimal(5, 2)
  isChainMember         Boolean       @default(false)
  chainName             String?
  assessmentCycleCount  Int           @default(0)
  onboardingData        Json          @default("{}")
  onboardingStep        Int           @default(0)

  // Public profile fields
  tagline               String?
  description           String?       @db.Text
  coverPhotoUrl         String?
  photos                String[]
  amenities             String[]
  address               String?
  lat                   Decimal?      @db.Decimal(10, 7)
  lng                   Decimal?      @db.Decimal(10, 7)
  isPublished           Boolean       @default(false)
  publicationBlockedReason String?
  qrCodeUrl             String?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user                     User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  territory                Territory?                @relation(fields: [territoryId], references: [id])
  assessmentSnapshots      AssessmentSnapshot[]
  scoreSnapshots           ScoreSnapshot[]
  forwardCommitmentRecords ForwardCommitmentRecord[]
  bookings                 Booking[]
  evidenceRefs             EvidenceRef[]
  activities               Activity[]
  reviews                  OperatorReview[]
  profileViews             ProfileView[]
  checkIns                 CheckIn[]

  @@map("operators")
}

// ── Assessment Snapshot (immutable after creation) ─────────────────────────

model AssessmentSnapshot {
  id                          String        @id @default(cuid())
  operatorId                  String
  territoryId                 String
  assessmentCycle             Int           @default(1)
  assessmentPeriodEnd         DateTime      @db.Date
  operatorType                OperatorType?
  guestNights                 Decimal?      @db.Decimal(10, 2)
  visitorDays                 Decimal?      @db.Decimal(10, 2)
  revenueSplitAccommodationPct Decimal?     @db.Decimal(5, 2)
  revenueSplitExperiencePct   Decimal?      @db.Decimal(5, 2)

  // Pillar 1
  p1EnergyIntensity           Decimal?      @db.Decimal(10, 4)
  p1RenewablePct              Decimal?      @db.Decimal(5, 2)
  p1WaterIntensity            Decimal?      @db.Decimal(10, 4)
  p1RecirculationScore        Int?
  p1WasteDiversionPct         Decimal?      @db.Decimal(5, 2)
  p1CarbonIntensity           Decimal?      @db.Decimal(10, 4)
  p1SiteScore                 Int?

  // Pillar 2
  p2LocalEmploymentRate       Decimal?      @db.Decimal(5, 2)
  p2EmploymentQuality         Decimal?      @db.Decimal(5, 2)
  p2LocalFbRate               Decimal?      @db.Decimal(5, 2)
  p2LocalNonfbRate            Decimal?      @db.Decimal(5, 2)
  p2DirectBookingRate         Decimal?      @db.Decimal(5, 2)
  p2LocalOwnershipPct         Decimal?      @db.Decimal(5, 2)
  p2CommunityScore            Int?

  // Pillar 3
  p3Status                    P3Status?
  p3CategoryScope             Int?
  p3Traceability              Int?
  p3Additionality             Int?
  p3Continuity                Int?
  p3ContributionCategories    String[]
  p3ProgrammeDescription      String?
  p3ProgrammeDuration         String?
  p3GeographicScope           String?
  p3AnnualBudget              Decimal?      @db.Decimal(15, 2)
  p3GuestsParticipating       Int?
  p3IsCollective              Boolean       @default(false)
  p3CollectiveSize            String?
  p3CollectiveTotalBudget     Decimal?      @db.Decimal(15, 2)
  p3CollectiveSharePct        Decimal?      @db.Decimal(5, 2)
  p3InstitutionName           String?

  // Delta block (null on Cycle 1)
  deltaPriorCycle             Int?
  deltaBaselineScores         Json?
  deltaPriorScores            Json?
  deltaCurrentScores          Json?

  snapshotHash                String?
  createdAt                   DateTime      @default(now())

  operator                    Operator               @relation(fields: [operatorId], references: [id])
  territory                   Territory              @relation(fields: [territoryId], references: [id])
  scoreSnapshots              ScoreSnapshot[]
  evidenceRefs                EvidenceRef[]

  @@map("assessment_snapshots")
}

// ── Evidence Reference (immutable) ─────────────────────────────────────────

model EvidenceRef {
  id                    String            @id @default(cuid())
  assessmentSnapshotId  String
  operatorId            String
  indicatorId           String
  tier                  EvidenceTier?
  fileName              String?
  storagePath           String?
  checksum              String?
  verificationState     VerificationState @default(pending)
  proxyMethod           String?
  proxyCorrectionFactor Decimal?          @db.Decimal(6, 4)
  submittedAt           DateTime          @default(now())
  verifiedAt            DateTime?
  verifiedBy            String?

  assessmentSnapshot    AssessmentSnapshot @relation(fields: [assessmentSnapshotId], references: [id])
  operator              Operator           @relation(fields: [operatorId], references: [id])

  @@map("evidence_refs")
}

// ── DPI Snapshot (immutable) ───────────────────────────────────────────────

model DpiSnapshot {
  id                     String        @id @default(cuid())
  territoryId            String
  methodologyVersion     String        @default("1.0.0")
  touristIntensity       Decimal       @db.Decimal(6, 2)
  ecologicalSensitivity  Decimal       @db.Decimal(6, 2)
  economicLeakageRate    Decimal       @db.Decimal(6, 2)
  regenerativePerf       Decimal       @db.Decimal(6, 2)
  compositeDpi           Decimal       @db.Decimal(6, 2)
  pressureLevel          PressureLevel
  operatorCohortSize     Int           @default(0)
  snapshotHash           String?
  createdAt              DateTime      @default(now())

  territory              Territory     @relation(fields: [territoryId], references: [id])
  scoreSnapshots         ScoreSnapshot[]

  @@map("dpi_snapshots")
}

// ── Score Snapshot (immutable) ─────────────────────────────────────────────

model ScoreSnapshot {
  id                    String       @id @default(cuid())
  assessmentSnapshotId  String
  operatorId            String
  dpiSnapshotId         String?
  methodologyVersion    String       @default("1.0.0")
  inputHash             String?
  bundleHash            String?

  p1Score               Decimal      @db.Decimal(6, 2)
  p2Score               Decimal      @db.Decimal(6, 2)
  p3Score               Decimal      @db.Decimal(6, 2)
  gpsTotal              Decimal      @db.Decimal(5, 2)
  gpsBand               GPSBand

  dpsTotal              Decimal?     @db.Decimal(6, 2)
  dps1                  Decimal?     @db.Decimal(6, 2)
  dps2                  Decimal?     @db.Decimal(6, 2)
  dps3                  Decimal?     @db.Decimal(6, 2)
  dpsBand               DPSBand?

  dpiScore              Decimal?     @db.Decimal(6, 2)
  dpiPressureLevel      PressureLevel?

  computationTrace      Json?
  isPublished           Boolean      @default(false)
  publicationBlockedReason String?
  computedAt            DateTime     @default(now())

  assessmentSnapshot    AssessmentSnapshot @relation(fields: [assessmentSnapshotId], references: [id])
  operator              Operator           @relation(fields: [operatorId], references: [id])
  dpiSnapshot           DpiSnapshot?       @relation(fields: [dpiSnapshotId], references: [id])
  bookings              Booking[]

  @@map("score_snapshots")
}

// ── Forward Commitment Record ──────────────────────────────────────────────

model ForwardCommitmentRecord {
  id                      String                  @id @default(cuid())
  operatorId              String
  assessmentCycle         Int
  preferredCategory       String?
  territoryContext        String?
  preferredInstitutionType String?
  targetActivationCycle   Int?
  authorisedSignatory     String?
  status                  ForwardCommitmentStatus @default(pending)
  matchedInstitution      String?
  activatedAt             DateTime?
  lapsedAt                DateTime?
  signedAt                DateTime?
  createdAt               DateTime                @default(now())

  operator                Operator @relation(fields: [operatorId], references: [id])

  @@map("forward_commitment_records")
}

// ── Methodology Bundle (versioned, never deleted) ─────────────────────────

model MethodologyBundleRecord {
  id          String   @id @default(cuid())
  version     String   @unique
  publishedAt DateTime @default(now())
  bundle      Json
  bundleHash  String
  signature   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("methodology_bundles")
}

// ── Traveler ───────────────────────────────────────────────────────────────

model Traveler {
  id                      String    @id @default(cuid())
  userId                  String?   @unique
  displayName             String?
  cumulativeChoiceScore   Decimal?  @db.Decimal(6, 2)
  totalContributionEvents Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Traveler passport / gamification
  level                   Int       @default(1)
  points                  Int       @default(0)
  publicSlug              String?   @unique
  avatarUrl               String?

  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings        Booking[]
  postTripReports PostTripReport[]
  checkIns        CheckIn[]
  activityRegs    ActivityRegistration[]
  badges          TravelerBadge[]
  reviews         OperatorReview[]
  missionSightings MissionSighting[]
  missionExplorations MissionExploration[]
  notifications   Notification[]

  @@map("travelers")
}

// ── Booking ────────────────────────────────────────────────────────────────

model Booking {
  id               String        @id @default(cuid())
  travelerId       String?
  operatorId       String
  scoreSnapshotId  String?
  dpiScoreAtBooking Decimal?     @db.Decimal(6, 2)
  checkIn          DateTime?     @db.Date
  checkOut         DateTime?     @db.Date
  nights           Int?
  status           BookingStatus @default(booked)
  createdAt        DateTime      @default(now())

  traveler         Traveler?      @relation(fields: [travelerId], references: [id])
  operator         Operator       @relation(fields: [operatorId], references: [id])
  scoreSnapshot    ScoreSnapshot? @relation(fields: [scoreSnapshotId], references: [id])
  postTripReport   PostTripReport?

  @@map("bookings")
}

// ── Post-Trip Report (immutable) ───────────────────────────────────────────

model PostTripReport {
  id                            String    @id @default(cuid())
  bookingId                     String    @unique
  travelerId                    String
  operatorId                    String
  renewableKwhUsed              Decimal?  @db.Decimal(10, 4)
  kwhVsRegionalAvg              Decimal?  @db.Decimal(6, 2)
  localEconomyEur               Decimal?  @db.Decimal(10, 2)
  contributionActivities        Json?
  destinationDpi                Decimal?  @db.Decimal(6, 2)
  pressureLevel                 String?
  destinationNote               String?
  cumulativeChoiceScoreAtReport Decimal?  @db.Decimal(6, 2)
  totalContributionEventsAtReport Int?
  generatedAt                   DateTime  @default(now())

  booking                       Booking  @relation(fields: [bookingId], references: [id])
  traveler                      Traveler @relation(fields: [travelerId], references: [id])

  @@map("post_trip_reports")
}

// ── Audit Log (append-only) ────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  actor         String?
  actorRole     AppRole?
  action        String
  entityType    String
  entityId      String?
  payload       Json?
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@map("audit_logs")
}

// ── Check-In (QR scan check-ins by travelers) ──────────────────────────────

model CheckIn {
  id            String    @id @default(cuid())
  travelerId    String
  operatorId    String
  pointsAwarded Int       @default(0)
  lat           Decimal?  @db.Decimal(10, 7)
  lng           Decimal?  @db.Decimal(10, 7)
  createdAt     DateTime  @default(now())

  traveler      Traveler  @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  operator      Operator  @relation(fields: [operatorId], references: [id])

  @@map("check_ins")
}

// ── Activity (experience listings) ────────────────────────────────────────

model Activity {
  id            String             @id @default(cuid())
  operatorId    String
  title         String
  description   String?            @db.Text
  type          String
  difficulty    ActivityDifficulty @default(moderate)
  durationMinutes Int?
  maxParticipants Int?
  pointsOnComplete Int             @default(0)
  photoUrl      String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  operator      Operator               @relation(fields: [operatorId], references: [id])
  registrations ActivityRegistration[]

  @@map("activities")
}

// ── Activity Registration ──────────────────────────────────────────────────

model ActivityRegistration {
  id          String    @id @default(cuid())
  travelerId  String
  activityId  String
  status      String    @default("registered") // registered | completed | cancelled
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  traveler    Traveler  @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  activity    Activity  @relation(fields: [activityId], references: [id])

  @@unique([travelerId, activityId])
  @@map("activity_registrations")
}

// ── Biodiversity Mission ───────────────────────────────────────────────────

model BiodiversityMission {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  description      String?   @db.Text
  species          String?
  speciesScientific String?
  category         String?   // marine | terrestrial | freshwater | cultural
  difficulty       ActivityDifficulty @default(easy)
  pointsPerSighting Int      @default(10)
  pointsPerExploration Int   @default(5)
  photoUrl         String?
  coverPhotoUrl    String?
  isNightWindow    Boolean   @default(false)
  isActive         Boolean   @default(true)
  territoryId      String?
  createdAt        DateTime  @default(now())

  sightings        MissionSighting[]
  explorations     MissionExploration[]

  @@map("biodiversity_missions")
}

// ── Mission Sighting (species photo submission) ────────────────────────────

model MissionSighting {
  id              String         @id @default(cuid())
  missionId       String
  travelerId      String
  photoUrl        String?
  thumbnailUrl    String?
  lat             Decimal?       @db.Decimal(10, 7)
  lng             Decimal?       @db.Decimal(10, 7)
  waterBodyName   String?
  depth           Decimal?       @db.Decimal(6, 2)
  behavior        String?
  notes           String?        @db.Text
  pointsAwarded   Int            @default(0)
  status          SightingStatus @default(pending)
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  createdAt       DateTime       @default(now())

  mission         BiodiversityMission @relation(fields: [missionId], references: [id])
  traveler        Traveler            @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@map("mission_sightings")
}

// ── Mission Exploration (location check-in for missions) ──────────────────

model MissionExploration {
  id              String    @id @default(cuid())
  missionId       String
  travelerId      String
  lat             Decimal?  @db.Decimal(10, 7)
  lng             Decimal?  @db.Decimal(10, 7)
  pointsAwarded   Int       @default(0)
  createdAt       DateTime  @default(now())

  mission         BiodiversityMission @relation(fields: [missionId], references: [id])
  traveler        Traveler            @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@map("mission_explorations")
}

// ── Traveler Badge ─────────────────────────────────────────────────────────

model TravelerBadge {
  id          String    @id @default(cuid())
  travelerId  String
  badge       BadgeType
  earnedAt    DateTime  @default(now())

  traveler    Traveler  @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([travelerId, badge])
  @@map("traveler_badges")
}

// ── Operator Review ────────────────────────────────────────────────────────

model OperatorReview {
  id          String    @id @default(cuid())
  operatorId  String
  travelerId  String
  rating      Int       // 1-5
  title       String?
  body        String?   @db.Text
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  operator    Operator  @relation(fields: [operatorId], references: [id])
  traveler    Traveler  @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@map("operator_reviews")
}

// ── Notification ───────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  travelerId  String
  type        NotificationType
  title       String
  body        String?
  link        String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  traveler    Traveler         @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── Profile View (operator analytics) ─────────────────────────────────────

model ProfileView {
  id          String    @id @default(cuid())
  operatorId  String
  viewedAt    DateTime  @default(now())
  referrer    String?
  country     String?

  operator    Operator  @relation(fields: [operatorId], references: [id])

  @@map("profile_views")
}

// ── Traveler Waitlist ──────────────────────────────────────────────────────

model TravelerWaitlist {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  source      String?
  createdAt   DateTime  @default(now())

  @@map("traveler_waitlist")
}
