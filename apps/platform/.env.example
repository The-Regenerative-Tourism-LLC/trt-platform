# ── Database ──────────────────────────────────────────────────────────────────
# Local development (matches docker-compose.yml at repo root)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trt_local"

# ── Auth.js v5 (NextAuth) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here-at-least-32-chars"

# Google OAuth — create credentials at https://console.cloud.google.com/
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── App ────────────────────────────────────────────────────────────────────────
# Set to the public URL of your app (required for OAuth callbacks in production)
# NEXTAUTH_URL="https://your-app.example.com"

# ── Email / Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_XXXXXXXX"
EMAIL_FROM="Green Passport <noreply@mail.theregenerativetourism.com>"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ADMIN_NOTIFICATION_EMAIL="admin@theregenerativetourism.com"

# ── Mapbox (address autocomplete + map preview in onboarding) ─────────────────
# Create a public token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN="pk...."

# ── File Storage ───────────────────────────────────────────────────────────────
# "local" for development, "s3" for staging/production
DRIVER="local"
# Local dev only — folder relative to project root
LOCAL_DIR="storage"
PUBLIC_BASE_URL="http://localhost:3000/uploads"

# Driver: "local" or "s3"
DRIVER=local

# Local storage (development)
STORAGE_LOCAL_DIR=storage
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/uploads

# S3 / Railway Object Storage (staging/production)
ENDPOINT=
REGION=auto
BUCKET=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
# Example: https://bucket.t3.storageapi.dev
# PUBLIC_BASE_URL=

# Upload limits
MAX_PHOTO_BYTES=10485760
MAX_EVIDENCE_BYTES=20971520
MAX_OPERATOR_PHOTOS=10