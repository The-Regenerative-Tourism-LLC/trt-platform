# ── Database ──────────────────────────────────────────────────────────────────
# Local development (matches docker-compose.yml at repo root)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trt_local"

# ── Auth.js v5 (NextAuth) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here-at-least-32-chars"

# Google OAuth — create credentials at https://console.cloud.google.com/
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── App ────────────────────────────────────────────────────────────────────────
# Set to the public URL of your app (required for OAuth callbacks in production)
# NEXTAUTH_URL="https://your-app.example.com"

# ── Email / Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_XXXXXXXX"
EMAIL_FROM="The Regenerative Tourism <noreply@mail.theregenerativetourism.com>"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ADMIN_NOTIFICATION_EMAIL="admin@theregenerativetourism.com"

# ── Mapbox (address autocomplete + map preview in onboarding) ─────────────────
# Create a public token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN="pk...."

# ── File Storage ───────────────────────────────────────────────────────────────
# "local" for development, "s3" for staging/production (Cloudflare R2 or AWS S3)
STORAGE_DRIVER=local

# Local storage (development) — files served via /uploads/[...path]
STORAGE_LOCAL_DIR=storage
# Public base URL used by next/image and public operator pages.
# Local default: http://localhost:3000/uploads
# Production: your R2 public bucket URL, e.g. https://pub-xxxx.r2.dev
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/uploads

# S3 / Cloudflare R2 (staging/production)
# STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_BUCKET_PUBLIC=trt-photos-public      # public-read bucket for operator photos
# STORAGE_BUCKET_PRIVATE=trt-evidence-private  # private bucket for evidence files
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev  # required for s3 driver

# Upload limits
STORAGE_MAX_PHOTO_BYTES=10485760
STORAGE_MAX_EVIDENCE_BYTES=20971520
STORAGE_MAX_OPERATOR_PHOTOS=10


# Seed Variables
SEED_CREATE_USERS=true
SEED_ADMIN_PASSWORD=Admin1234!
SEED_OPERATOR_PASSWORD=Operator1234!
SEED_TRAVELER_PASSWORD=Traveler1234!

# ── Klaviyo ───────────────────────────────────────────────────────────────
# Server-side only — never expose to the browser
KLAVIYO_API_KEY=